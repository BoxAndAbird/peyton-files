; Below the Hollow - Godot 4 project configuration
; ------------------------------------------------------------------
; NOTE ON INPUT MAP:
;   Input actions are registered at runtime by SettingsManager via
;   res://scripts/core/InputActions.gd. This is deliberate: hand-authored
;   InputEventKey blocks in project.godot are extremely version-fragile,
;   while runtime registration is 100% reliable and also lets the settings
;   menu rebind keys. The editor "Input Map" tab will look empty; that is
;   expected and does not affect the running game.
; ------------------------------------------------------------------

config_version=5

[application]

config/name="Below the Hollow"
config/description="Psychological horror roguelike. PS2-era low-poly, readable lighting."
run/main_scene="res://scenes/core/Main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

; Order matters: earlier autoloads must not depend on later ones during _ready().
EventBus="*res://scripts/core/EventBus.gd"
Database="*res://scripts/data/Database.gd"
AudioManager="*res://scripts/audio/AudioManager.gd"
SettingsManager="*res://scripts/core/SettingsManager.gd"
SaveManager="*res://scripts/core/SaveManager.gd"
RunManager="*res://scripts/core/RunManager.gd"
GameManager="*res://scripts/core/GameManager.gd"
DebugConsole="*res://scripts/core/DebugConsole.gd"
MusicDirector="*res://scripts/audio/MusicDirector.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[physics]

; Named 3D collision layers (helps readability across the codebase).
; 1=world 2=player 3=enemy 4=player_hitbox 5=enemy_hitbox 6=interactable 7=projectile
3d/layer_names/world="world"
3d/layer_names/player="player"
3d/layer_names/enemy="enemy"
3d/layer_names/player_hitbox="player_hitbox"
3d/layer_names/enemy_hitbox="enemy_hitbox"
3d/layer_names/interactable="interactable"
3d/layer_names/projectile="projectile"

[rendering]

renderer/rendering_method="forward_plus"
environment/defaults/default_clear_color=Color(0.04, 0.045, 0.06, 1)
anti_aliasing/quality/msaa_3d=1
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=2
